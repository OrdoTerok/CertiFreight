{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "cross-env E2E_COVERAGE=true playwright test --config=playwright.config.mjs",
    "test:e2e:ui": "cross-env E2E_COVERAGE=true playwright test --config=playwright.config.mjs --ui",
    "coverage:e2e": "node -e \"const fs=require('node:fs'); fs.rmSync('.nyc_output',{recursive:true,force:true}); fs.rmSync('coverage-e2e',{recursive:true,force:true});\" && npm run test:e2e && nyc report --nycrc-path .nycrc.e2e.json && nyc check-coverage --nycrc-path .nycrc.e2e.json"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "axios": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@playwright/test": "^1.55.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "cross-env": "^10.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "nyc": "^17.1.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite-plugin-istanbul": "^9.0.1",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
